{
  "name": "pdf-service",
  "version": "1.2.2",
  "description": "Starter project for an ES6 RESTful Express API",
  "main": "dist",
  "scripts": {
    "dev": "nodemon -w src --exec \"babel-node src\"",
    "build": "babel src -s -D -d dist",
    "start": "node --max-old-space-size=8192 dist",
    "prestart": "npm run -s build",
    "test": "eslint src"
  },
  "proxy": "https://egov-micro-dev.egovernments.org/",
  "eslintConfig": {
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 7,
      "sourceType": "module"
    },
    "env": {
      "node": true
    },
    "rules": {
      "no-console": 0,
      "no-unused-vars": 1
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egovernments/core-services.git"
  },
  "author": "Jason Miller <jason@developit.ca>",
  "license": "MIT",
  "engines": {
    "node": ">=20.19 <21"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "async": "^3.2.6",
    "axios": "^1.15.2",
    "base64-stream": "^1.0.0",
    "body-parser": "^2.2.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "form-data": "^4.0.5",
    "jsonpath-plus": "^10.4.0",
    "kafka-node": "^5.0.0",
    "lodash.get": "^4.4.2",
    "moment-timezone": "^0.6.1",
    "morgan": "^1.10.1",
    "node-cache": "^5.1.2",
    "pdf-merger-js": "^5.1.2",
    "pdfmake": "^0.2.23",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "uuid": "^14.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/node": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "eslint": "^10.2.1",
    "mustache": "^4.2.0",
    "nodemon": "^3.1.14"
  },
  "bugs": {
    "url": "https://github.com/egovernments/core-services/issues"
  },
  "homepage": "https://github.com/egovernments/core-services/blob/master/README.md",
  "overrides": {
    "minimist": "^1.2.8",
    "mkdirp": "^1.0.4",
    "semver": "^7.7.4",
    "lodash": "^4.17.21"
  }
}
